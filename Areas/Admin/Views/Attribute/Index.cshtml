@{
	ViewData["Title"] = "Attributes";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
	<div class="container-fluid">
		<div class="row mb-2">
			<div class="col-sm-6">
				<h1 class="m-0 font-weight-bold">Attributes</h1>
			</div>
			<div class="col-sm-6">
				<div class="float-sm-right">
					<button type="button" id="btnAddNewItem" class="btn btn-primary btn-md pull-right mr-2 divformSave_Hide"
							onclick="fnLoadParialView('divformSave', '@Url.Action("Partial_AddEditForm", "Attribute", new { area = "Admin" })');">
						<i class="fas fa-plus"></i> &nbsp; Add Attribute
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<section class="content">
	<div class="container-fluid">

		<div class="row no-gutters divformSave_Display d-none" style="margin:5px !important;">
			<div class="col-12">
				<form id="formSave" asp-area="Admin" asp-controller="Attribute" asp-action="Save" method="post" class="form-horizontal">
					<div class="row no-gutters" id="divformSave"></div>
					<div class="clearfix"></div>
					<hr />
				</form>
			</div>
		</div>

		<div class="row divformSave_Hide">
			<div class="col-12">
				<div class="card card-primary card-outline">
					<div class="card-body">
						<div class="row no-gooters">
							<div class="col-md-12 my-1">
								<table id="table_Common_Data" class="table table-bordered table-striped w-100"></table>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

	</div>
</section>

@section Scripts
{
	<script>

		$(document).ready(function () { fnLoadTableData(); });

		function fnLoadTableData(){

			if ($.fn.DataTable.isDataTable('#table_Common_Data')){
				$('#table_Common_Data').DataTable().destroy();
			}

			$("#table_Common_Data").DataTable({

				"destroy": true,
				"paging": true,
				"searching": true,
				"ordering": true,
				"pageLength": 25,
				"sAjaxSource": "@Url.Action("GetDataList", "Attribute", new { area = "Admin" })",
				"bServerSide": true,
				"bProcessing": true,
				"order": [[0, 'desc']],
				columnDefs: [
					{ "targets":0,"className":"text-center","width":"3%","orderable":false },
					{ "targets":-1,"className":"text-center","width":"5%","orderable":false }
				],
				columns: [
					{
						title:"<input type='checkbox' id='chkAll' />",
						data:"Id",
						render:function(data){
							return '<input type="checkbox" class="chkRow" value="'+data+'" />';
						}
					},
					{ title:"No.", data:"SrNo", className:"text-center" },
					{ title:"Attribute", data:"Name" },
					{ title:"Display name", data:"DisplayName" },
					{ title:"Values", data:"Values" },
					{
						title:"Status",
						data:"IsActive",
						className:"text-center",
						render:function(data){
							return data
							? '<span class="badge badge-success">Active</span>'
							: '<span class="badge badge-danger">Inactive</span>';
						}
					},
					{
						title:"Action",
						data:null,
						className:"text-center",
						render:function(data,type,row){

							return '<div class="btn-group">'+
							'<button class="btn btn-info btn-sm" title="Edit" '+
							'onclick="fnLoadParialView(\'divformSave\', \'@Url.Action("Partial_AddEditForm", "Attribute", new { area = "Admin" })?Id='+row.Id+'\')">'+
							'<i class="far fa-edit"></i></button>'+

							'<button class="btn btn-danger btn-sm ml-2" title="Delete" '+
							'onclick="fnDelete_Confirm(\'@Url.Action("DeleteConfirmed", "Attribute", new { area = "Admin" })?Id='+row.Id+'\')">'+
							'<i class="fa fa-trash"></i></button>'+

							'</div>';
						}
					}
				]
			});
		}

	</script>
}