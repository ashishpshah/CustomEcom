@model ResponseModel<Coupons>

@{
	Layout = null;

	var IndexPageUrl = "/" + ViewContext.RouteData.Values["Area"] + "/" +
								ViewContext.RouteData.Values["Controller"] + "/Index";
	var discountType = Model.Obj?.DiscountType?.Trim().ToLower();
}


<div class="col-12">

	<div class="card card-primary card-outline mb-0">

		<div class="card-header">

			<h3 class="card-title">
				@(Model.Obj.Id > 0 ? "Edit" : "Create") Coupon
			</h3>

			<input type="hidden" name="Id" value="@Model.Obj?.Id" />

			<div class="card-tools">

				<button type="button"
						class="btn btn-primary btn-sm"
						onclick="fnBackToList('@IndexPageUrl')">

					<i class="fas fa-arrow-left"></i> Back To List

				</button>

			</div>

		</div>

		<div class="card-body form-horizontal">

			<div class="row">
				<div class="col-12">

					<!-- ROW 1 -->

					<div class="form-group row pt-3">

						<label class="col-2 col-form-label text-right">
							Coupon Code <span style="color:red">*</span>
						</label>

						<div class="col-sm-4">
							<input type="text"
								   class="form-control form-control-sm"
								   name="CouponCode"
								   value="@Model.Obj?.CouponCode"
								   maxlength="50"
								   placeholder="Coupon Code"
								   autocomplete="off"
								   data-required
								   data-msg="Coupon Code required">
						</div>


						<label class="col-2 col-form-label text-right">
							Discount Type <span style="color:red">*</span>
						</label>

						<div class="col-sm-4">


							<select asp-for="Obj.DiscountType"
									id="DiscountType"
									name="DiscountType"
									class="form-control form-control-sm"
									data-required
									data-msg="Discount Type required">

								<option value="">Select Discount Type</option>
								<option value="Flat">Flat</option>
								<option value="Percentage">Percentage</option>

							</select>
						</div>

					</div>



					<!-- ROW 2 -->

					<div class="form-group row pt-3">

						<label class="col-2 col-form-label text-right">
							Discount Value <span style="color:red">*</span>
						</label>

						<div class="col-sm-4">
							<input type="number"
								   step="0.01"
								   class="form-control form-control-sm"
								   name="DiscountValue"
								   value="@Model.Obj?.DiscountValue"
								   placeholder="Discount Value"
								   min="1"
								   max="999999"
								   oninput="if(this.value.length > 6) this.value = this.value.slice(0,6);"
								   onkeydown="return !['e','E','+','-'].includes(event.key)"
								   data-required
								   data-msg="Discount Value required">
						</div>


						<label class="col-2 col-form-label text-right">
							Minimum Order <span style="color:red">*</span>
						</label>

						<div class="col-sm-4">
							<input type="number"
								   step="0.01"
								   class="form-control form-control-sm"
								   name="MinimumOrderAmount"
								   value="@Model.Obj?.MinimumOrderAmount"
								   placeholder="Minimum Order Amount"
								   min="1"
								   max="9999999"
								   oninput="if(this.value.length > 7) this.value = this.value.slice(0,7);"
								   onkeydown="return !['e','E','+','-'].includes(event.key)"
								   data-required
								   data-msg="Minimum Order required">
						</div>

					</div>



					<!-- ROW 3 -->

					<div class="form-group row pt-3">

						<label class="col-2 col-form-label text-right">
							Expiry Date <span style="color:red">*</span>
						</label>

						<div class="col-sm-4">
							<input type="date"
								   class="form-control form-control-sm"
								   name="ExpiryDate"
								   value="@(Model.Obj?.ExpiryDate?.ToString("yyyy-MM-dd"))"
								   data-required
								   data-msg="Expiry Date required">
						</div>


						<label class="col-2 col-form-label text-right">
							Usage Limit <span style="color:red">*</span>
						</label>

						<div class="col-sm-4">
							<input type="number"
								   class="form-control form-control-sm"
								   name="UsageLimit"
								   value="@Model.Obj?.UsageLimit"
								   placeholder="Usage Limit"
								   min="1"
								   max="999"
								   oninput="if(this.value.length > 3) this.value = this.value.slice(0,3);"
								   onkeydown="return !['e','E','+','-','.'].includes(event.key)"
								   data-required
								   data-msg="Usage Limit required">
						</div>

					</div>


				</div>
			</div>

		</div>
