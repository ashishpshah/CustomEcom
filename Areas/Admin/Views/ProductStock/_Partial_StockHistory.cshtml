@model ResponseModel<ProductStock>

<div class="card card-primary card-outline">

	<div class="card-header">
		<h3 class="card-title">Adjust Stock</h3>
	</div>

	<div class="card-body">

		<input type="hidden" name="VariantId" value="@Model.Obj.VariantId" />

		<div class="form-group row">

			<label class="col-sm-3 col-form-label text-right">
				Change Type
			</label>

			<div class="col-sm-6">

				<select name="ChangeType" class="form-control form-control-sm">

					<option value="IN">Stock In</option>
					<option value="OUT">Stock Out</option>
					<option value="RESERVE">Reserve</option>
					<option value="RELEASE">Release</option>

				</select>

			</div>

		</div>


		<div class="form-group row">

			<label class="col-sm-3 col-form-label text-right">
				Quantity
			</label>

			<div class="col-sm-6">

				<input type="number"
					   class="form-control form-control-sm"
					   name="Quantity"
					   min="1" />

			</div>

		</div>


		<div class="form-group row">

			<label class="col-sm-3 col-form-label text-right">
				Remarks
			</label>

			<div class="col-sm-6">

			<textarea class="form-control form-control-sm" name="Remarks"></textarea>

			</div>

		</div>

	</div>

	<div class="card-footer text-center">

		<button type="button" class="btn btn-success">Save</button>

	</div>

</div>