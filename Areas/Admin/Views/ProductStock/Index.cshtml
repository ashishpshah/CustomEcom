@{
	ViewData["Title"] = "ProductStock";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
	<div class="container-fluid">
		<div class="row mb-2">
			<div class="col-sm-6">
				<h1 class="m-0 font-weight-bold">Product Stock</h1>
			</div>
			<div class="col-sm-6">
				<div class="float-sm-right">
					<button type="button" id="btnAddNewItem" class="btn btn-primary btn-md pull-right mr-2 divformSave_Hide"
							onclick="fnLoadParialView('divformSave', '@Url.Action("Partial_AddEditForm", "ProductStock", new { area = "Admin" })');">
						<i class="fas fa-plus"></i> &nbsp; Add Product Stock
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<section class="content">
	<div class="container-fluid">
		<div class="row no-gutters divformSave_Display d-none" style="margin: 5px !important;">
			<div class="col-12">
				<form id="formSave" asp-area="Admin" asp-controller="ProductStock" asp-action="Save" method="post" class="form-horizontal" enctype="multipart/form-data">
					<div class="row no-gutters" id="divformSave"></div>
					<div class="clearfix"></div>
					<hr />
				</form>
			</div>
		</div>
		<div class="row divformSave_Hide">
			<div class="col-12">
				<div class="card card-primary card-outline">

					<div class="card-body">
						<div class="row no-gooters">
							<div class="col-md-12 my-1">
								<table id="table_Common_Data" class="table table-bordered table-striped w-100"> </table>
							</div>

							<div class="clearfix"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>



@section Scripts
{
	<script type="text/javascript">

		$(document).ready(function () { fnLoadTableData(); });

		function fnLoadTableData() {

			if ($.fn.DataTable.isDataTable('#table_Common_Data')) { $('#table_Common_Data').DataTable().destroy(); }

			$("#table_Common_Data").DataTable({
				"destroy": true,
				"paging": true,
				"lengthChange": true,
				"searching": true,
				"ordering": true,
				"info": true,
				"autoWidth": false,
				"responsive": true,
				"pageLength": 25,
				"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
				"sAjaxSource": "@Url.Action("GetDataList", "ProductStock", new { area = "Admin" })",
				"bServerSide": true,
				"bProcessing": true,
				"bSearchable": true,
				"order": [[0, 'desc']],
				"language": { "emptyTable": "No record found.", "processing": '<i class="fa fa-spinner fa-spin fa-3x fa-fw" style="color:#2a2b2b;"></i><span class="sr-only">Loading...</span> ' },
				"fnServerParams": function (aoData) {
					//aoData.push({ "name": "SearchTerm", "value": "" + $('#inputSearch').val() });
				},
				columnDefs: [
					{ "targets": 0, "className": "text-center", "width": "3%", "autoWidth": false, "searchable": false, "orderable": false },
					{ "targets": -1, "className": "text-center", "width": "5%", "autoWidth": false, "searchable": false, "orderable": false }
				],
				"columns": [
					{ title: "No.", data: "SrNo", width: "5%", className: "text-center" },
					{ title: "Product", data: "ProductName" },
					{ title: "SKU", data: "SKU" },
					{ title: "Available Stock", data: "AvailableStock", className:"text-center" },
					{ title: "Reserved Stock", data: "ReservedStock", className:"text-center" },
					{ title: "Total Stock", data: "TotalStock", className:"text-center" },
					{
						title: "Action",
						data: null,
						orderable: false,
						className: "text-center",
						render: function (data, type, row) {
							return '<div class="btn-group">' +
								'<button type="button" class="btn btn-success btn-sm btn-flat" data-toggle="tooltip" data-placement="top" title="Edit" ' +
								'onclick="fnViewStockHistory(' + row.ProductId + ',' + row.VariantId + ')">' +
								'<i class="fa fa-history"></i></button> ' +
								// '<button type="button" class="btn btn-danger btn-sm btn-flat ml-2" data-toggle="tooltip" data-placement="top" title="Delete" ' +
								// 'onclick="fnDelete_Confirm(\'@Url.Action("DeleteConfirmed", "ProductStock", new { area = "Admin" })?Id=' + row.Id + '\')">' +
								// '<i class="fa fa-trash"></i></button> ' +
								'</div>';
						}
					}
				]
			});
		}

		function fnSaveStockAdjust(){

			var data = {

				ProductId: $("#ProductId").val(),
				VariantIds: $("#VariantIds").val().join(),
				ChangeType: $("select[name='ChangeType']").val(),
				Quantity: $("input[name='Quantity']").val(),
				Remarks: $("textarea[name='Remarks']").val()

			};
			debugger;
			$.post("@Url.Action("AdjustStock", "ProductStock", new { area = "Admin" })", data, function(response){

				try {
					ShowLoader(false);
					if (response.IsSuccess === true) {

						fnCloseParialView('divformSave');

						if ($.fn.DataTable.isDataTable('#table_Common_Data')) {
							$('#table_Common_Data').DataTable().ajax.reload(null, false);
						}
					}
					else { CommonAlert_Error(response.Message, null) }
				} catch { window.location.reload(); }

			});

		}

		function fnLoadVariants(productId){

			if(!productId){
				$("#VariantIds").html('');
				return;
			}

			$.get("@Url.Action("GetVariants", "ProductStock", new { area = "Admin" })",
				{ productId: productId },
				function(res){

					let html = '';

					res.forEach(function(v){
						html += '<option value="'+v.Id+'">'+v.SKU+'</option>';
					});

					$("#VariantIds").html(html);
					$("#VariantIds").val(null).trigger('change');

				});

		}

		function fnViewStockHistory(productId, variantId,) {

			$.get("@Url.Action("GetStockHistory", "ProductStock", new { area = "Admin" })", { ProductId: productId, VariantId: variantId }, function (res) {

				var product = res.product;
				var history = res.history;

				var historyHtml = buildHistoryTimeline(history);

				Swal.fire({
					width: "1000px",
					showCloseButton: true,
					showConfirmButton: false,
					html: `
						<div class="text-left">

							<div class="mb-3 p-3 border rounded bg-light">

								<h5 class="mb-1">
									${product.ProductName}
								</h5>

								<div class="text-muted">
									SKU : ${product.SKU}
								</div>

								<div class="mt-2">

									<span class="badge badge-success mr-2">
										Available : ${product.AvailableStock}
									</span>

									<span class="badge badge-warning mr-2">
										Reserved : ${product.ReservedStock}
									</span>

									<span class="badge badge-primary">
										Total : ${product.TotalStock}
									</span>

								</div>

							</div>

							<div style="max-height:400px;overflow:auto">
								${historyHtml}
							</div>

						</div>
					`
				});

			});

		}

		function buildHistoryTimeline(data) {

			let html = "";
			let currentDate = "";

			data.forEach(item => {

				// let date = item.LastModifiedDate;

				// if (currentDate !== date) {

				// 	currentDate = date;

				// 	html += `
				// 		<div class="mt-3 mb-1 font-weight-bold text-primary">
				// 			${date}
				// 		</div>
				// 	`;
				// }

				html += `
					<div class="border rounded p-2 mb-2 d-flex justify-content-between">

						<div>

							<span class="badge ${getBadge(item.ChangeType)} mr-2">
								${item.ChangeType}
							</span>

							Qty : <b>${item.Quantity}</b>

							<div class="text-muted small">
								${item.Remarks ?? ''}
							</div>

						</div>

						<div class="text-muted small">
							${item.LastModifiedDate}
						</div>

					</div>
				`;
			});

			return html;
		}

		function getBadge(type){

			switch(type){

				case "IN":
					return "badge-success";

				case "OUT":
					return "badge-danger";

				case "RESERVE":
					return "badge-warning";

				case "RELEASE":
					return "badge-info";

				case "SALE":
					return "badge-primary";

				default:
					return "badge-secondary";
			}

		}
	</script>
}
