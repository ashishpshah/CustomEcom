		function fnParialView_Loaded_Success($id, $isAlert){
			initImageUploader();
		}

		function fnBtnAddNewItem() {

			var rowCount = $('#orderItemsTable tbody tr').length;
			let newRowId = "tr_" + rowCount;
			let varaintlist = @Html.Raw(Json.Serialize(Model.SelectListItems.Where(x => x.Group == "VARIANT")));
			var options = '<option value="0">Select</option>';

				varaintlist.forEach(varaint => {
					options += `<option value="${varaint.Value}" data-value="${varaint.Value4}">${varaint.Text}</option>`;
				});

			let newRow = `<tr id="${newRowId}">
			<td width="10%">
					<select class="form-control show-tick select2"
						id="ListOrderItems_${rowCount}_VariantId"
						name="ListOrderItems[${rowCount}].VariantId" onchange="onProductVaraintChange(this)" >
						${options}
					</select>
			</td>
			<td><input type="text" id="ListOrderItems_${rowCount}_Quantity" name="ListOrderItems[${rowCount}].Quantity" class="form-control isNumberKey_Decimal" value="" onkeyup="calculateRow(this),calculateTotals()" maxlength="18"/></td>
			<td><input type="text" id="ListOrderItems_${rowCount}_UnitPrice" name="ListOrderItems[${rowCount}].UnitPrice" class="form-control isNumberKey_Decimal" value="" readonly maxlength="18"/></td>
			<td><input type="text" id="ListOrderItems_${rowCount}_TotalPrice" name="ListOrderItems[${rowCount}].TotalPrice" class="form-control isNumberKey_Decimal" value="" readonly maxlength="18" /></td>
			<td><div><button type="button" class="btn btn-danger btn-sm btn-flat ml-2 deletebtn" data-toggle="tooltip" data-placement="top" title="Delete" onclick="deleteRow(this)">
			<i class="fa fa-trash"></i></button></div></td></tr>`;


			  setTimeout(() => {
				$(".select2").select2();
			}, 100);
			$("#orderItemsTable tbody").append(newRow);

			rowCount++;
		}

		$(document).on('click', '.deletebtn', function () {
			$(this).closest('tr').remove(); // Find the closest row (<tr>) to the clicked delete button and remove it
			calculateTotals();
		});
		function onProductVaraintChange(element) {

			var row = $(element).closest("tr");

			var price = $(element).find("option:selected").data("value") || 0;

			row.find("[id*='UnitPrice']").val(price);
			row.find("[id*='Quantity']").val(1);

			var total = price * 1;
			row.find("[id*='TotalPrice']").val(total.toFixed(2));

			calculateTotals();
		}
		function calculateRow(element) {

			var row = $(element).closest("tr");

			var qty = parseFloat(row.find("[id*='Quantity']").val()) || 0;
			var price = parseFloat(row.find("[id*='UnitPrice']").val()) || 0;

			var total = qty * price;

			row.find("[id*='TotalPrice']").val(total.toFixed(2));

			calculateTotals();
		}
		function calculateTotals() {

			var totalAmount = 0;

			$("#orderItemsTable tbody tr").each(function () {

				var total = parseFloat($(this).find("[id*='TotalPrice']").val()) || 0;
				totalAmount += total;

			});

			$("#TotalAmount").val(totalAmount.toFixed(2));

			var discount = parseFloat($("#DiscountAmount").val()) || 0;

			var finalAmount = totalAmount - discount;
			if (finalAmount <= 0) {
				CommonAlert_Error("Discount amount cannot be greater than Total Amount.");
				$('#DiscountAmount').val(0);
				finalAmount = totalAmount;
			}

			$("#FinalAmount").val(finalAmount.toFixed(2));
		}

	</script>
}
