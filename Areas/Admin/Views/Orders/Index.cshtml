@model ResponseModel<Orders>
@{
	ViewData["Title"] = "Orders";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}




@section styles {
	<style type="text/css">
		.text-muted {
			color: #888;
			font-size: 12px;
		}

		/* Filter Container */
		.status-filter {
			display: flex;
			gap: 10px;
			flex-wrap: wrap;
		}

		/* Base Button */
		.status-btn {
			padding: 6px 14px;
			border-radius: 50px;
			font-size: 13px;
			cursor: pointer;
			background: #f1f3f6;
			color: #555;
			transition: all 0.25s ease;
			border: 1px solid transparent;
		}

			/* Hover Effect */
			.status-btn:hover {
				background: #e2e6ea;
			}

			/* Active */
			.status-btn.active {
				background: #232f3e;
				color: #fff;
			}

			/* Individual Colors */
			.status-btn.pending.active {
				background: #ff9800 !important;
			}

			.status-btn.confirmed.active {
				background: #17a2b8 !important;
			}

			.status-btn.processing.active {
				background: #007bff !important;
			}

			.status-btn.completed.active {
				background: #28a745 !important;
			}

			.status-btn.cancelled.active {
				background: #dc3545 !important;
			}

			.status-btn.returned.active {
				background: #6c757d !important;
			}

		/* TABLE */
		.table {
			border-radius: 10px;
			overflow: hidden;
			background: #fff;
		}

			.table thead th {
				background: #f8f9fa;
				font-weight: 600;
				font-size: 14px;
			}

			.table tbody tr:hover {
				background: #f6f8fb;
			}

		/* STATUS BADGES */
		.badge-status {
			padding: 6px 10px;
			border-radius: 50px;
			font-size: 12px;
			font-weight: 500;
		}

		/* Amazon-like colors */
		.badge-pending {
			background: #fff3cd;
			color: #856404;
		}

		.badge-confirmed {
			background: #d1ecf1;
			color: #0c5460;
		}

		.badge-processing {
			background: #cce5ff;
			color: #004085;
		}

		.badge-completed {
			background: #d4edda;
			color: #155724;
		}

		.badge-cancelled {
			background: #f8d7da;
			color: #721c24;
		}

		.badge-returned {
			background: #e2e3e5;
			color: #383d41;
		}

		/* Card */
		.card {
			border-radius: 12px;
		}
	</style>
}
<div class="content-header">
	<div class="container-fluid">
		<div class="row mb-2">
			<div class="col-sm-6">
				<h1 class="m-0 font-weight-bold">Order</h1>
			</div>
			<div class="col-sm-6">
				<div class="float-sm-right">
					<button type="button" id="btnAddNewItem" class="btn btn-primary btn-md pull-right mr-2 divformSave_Hide"
							onclick="fnLoadParialView('divformSave', '@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })');">
						<i class="fas fa-plus"></i> &nbsp; Add Order
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<section class="content">
	<div class="container-fluid">
		<div class="row no-gutters divformSave_Display d-none" style="margin: 5px !important;">
			<div class="col-12">
				<form id="formSave" asp-area="Admin" asp-controller="Orders" asp-action="Save" method="post" class="form-horizontal" enctype="multipart/form-data">
					<div class="row no-gutters" id="divformSave"></div>
					<div class="clearfix"></div>
					<hr />
				</form>
			</div>
		</div>
		<div class="row divformSave_Hide">
			<div class="col-12">
				<div class="card card-primary card-outline">

					<div class="card-body">
						<div class="row no-gooters">
							<div class="col-md-12 my-1">
								<!-- STATUS FILTER -->
								<div class="status-filter mb-3">
									<label class="status-btn active" data-status="">
										All &nbsp; &nbsp;(<span id="count_ALL">0</span>)
									</label>

									@foreach (var item in Model.SelectListItems.Where(x => x.Group == "OS"))
									{
										<label class="status-btn status-@item.Text.ToLower()" data-status="@item.Value">
											@item.Text &nbsp; &nbsp;(<span id="count_@item.Value">0</span>)
										</label>
									}

								</div>
							</div>

							<div class="clearfix"></div>
						</div>
						<div class="row no-gooters">
							<div class="col-md-12 my-1">
								<table id="table_Common_Data" class="table table-bordered table-striped w-100" data-select-all="false"> </table>
							</div>

							<div class="clearfix"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>



@section Scripts
{
	<script type="text/javascript">

		const statusFlow = {
			PEND: ["CONF", "CANC"],          // Pending → Confirmed / Cancelled
			CONF: ["PROC", "CANC"],          // Confirmed → Processing / Cancelled
			PROC: ["COMP", "CANC"],          // Processing → Completed / Cancelled
			COMP: [],						// Completed → no further changes
			CANC: [],                        // Cancelled → no further changes
			RET: []                          // Returned → no further changes
		};

		const statusLabels = {
			PEND: "Pending",
			CONF: "Confirmed",
			PROC: "Processing",
			COMP: "Completed",
			CANC: "Cancelled",
			RET: "Returned"
		};
		var table_Common_Data = {};
		var selectedStatus = "";

		$(document).ready(function () {

			fnLoadTableData();

			$('.status-btn').on('click', function () {

				$('.status-btn').removeClass('active');
				$(this).addClass('active');

				selectedStatus = $(this).data("status");

				fnLoadTableData();
			});

		});

		function fnLoadTableData() {

			if ($.fn.DataTable.isDataTable('#table_Common_Data')) { $('#table_Common_Data').DataTable().destroy(); }

			table_Common_Data = $("#table_Common_Data").DataTable({
				"destroy": true,
				"paging": true,
				"lengthChange": true,
				"searching": true,
				"ordering": true,
				"info": true,
				"autoWidth": false,
				"responsive": true,
				"pageLength": 25,
				"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
				"sAjaxSource": "@Url.Action("GetDataList", "Orders", new { area = "Admin" })",
				"bServerSide": true,
				"bProcessing": true,
				"bSearchable": true,
				"order": [[2, 'desc']],
				"language": { "emptyTable": "No record found.", "processing": '<i class="fa fa-spinner fa-spin fa-3x fa-fw" style="color:#2a2b2b;"></i><span class="sr-only">Loading...</span> ' },
				"sAjaxDataProp": "aaData",
				"fnServerParams": function (aoData) {
					var status = $('.status-btn.active').data('status');
					aoData.push({ "name": "sStatus", "value": status });
				},
				columnDefs: [
					{ "targets": 0, "className": "text-center", "width": "3%", "autoWidth": false, "searchable": false, "orderable": false },
					{ "targets": -1, "className": "text-center", "width": "5%", "autoWidth": false, "searchable": false, "orderable": false }
				],
				"columns": [
					{
						title: "<input type='checkbox' id='chkAll' />",
						data: "Id",
						orderable: false,
						searchable: false,
						className: "text-center",
						render: function (data) {
							return '<input type="checkbox" class="chkRow" value="' + data + '" />';
						}
					},
					{ title: "Sr.No.", data: "SrNo", width: "5%", className: "text-center" },
					{ title: "Order No.", data: "OrderNumber" },
					{
						title: "Order Date",
						data: "OrderDate",
						render: function (data, type) {
							if (!data) return '';

							var date = new Date(data);

							// ✅ For sorting (very important)
							if (type === 'sort' || type === 'type') {
								return date.getTime();
							}

							// ✅ Format: dd-MMM-yyyy HH:mm
							var day = ("0" + date.getDate()).slice(-2);
							var monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
							var month = monthNames[date.getMonth()];
							var year = date.getFullYear();

							var hours = ("0" + date.getHours()).slice(-2);
							var minutes = ("0" + date.getMinutes()).slice(-2);

							var formattedDate = day + "-" + month + "-" + year + " " + hours + ":" + minutes;

							// ✅ Relative time calculation
							var now = new Date();
							var diffMs = now - date;
							var diffDays = diffMs / (1000 * 60 * 60 * 24);

							// 👉 Only show relative if within 5 days
							if (diffDays <= 5) {

								var seconds = Math.floor(diffMs / 1000);

								if (seconds < 60)
									return formattedDate + " <span class='text-muted'>(just now)</span>";

								var minutesDiff = Math.floor(seconds / 60);
								if (minutesDiff < 60)
									return formattedDate + " <span class='text-muted'>(" + minutesDiff + " min ago)</span>";

								var hoursDiff = Math.floor(minutesDiff / 60);
								if (hoursDiff < 24)
									return formattedDate + " <span class='text-muted'>(" + hoursDiff + " hours ago)</span>";

								var daysDiff = Math.floor(hoursDiff / 24);
								return formattedDate + " <span class='text-muted'>(" + daysDiff + " days ago)</span>";
							}

							// ✅ Older than 5 days → no relative
							return formattedDate;
						}
					},
					{ title: "No.Of.Items", data: "No_Of_Items" },
					{ title: "Final Amount", data: "FinalAmount" },
					{
						title: "Status",
						data: "OrderStatus",
						className: "text-center", width: "10%",
						//render: function (data) { return data == 'PEND' ? '<span class="badge badge-danger">Pending</span>' : '<span class="badge badge-success">Completed</span>'; }
						render: function (data) {
							switch (data) {
								case 'PEND':
									return '<span class="badge-status badge-pending">Pending</span>';

								case 'CONF':
									return '<span class="badge-status badge-confirmed">Confirmed</span>';

								case 'PROC':
									return '<span class="badge-status badge-processing">Processing</span>';

								case 'COMP':
									return '<span class="badge-status badge-completed">Completed</span>';

								case 'CANC':
									return '<span class="badge-status badge-cancelled">Cancelled</span>';

								case 'RET':
									return '<span class="badge-status badge-returned">Returned</span>';

								default:
									return '<span class="badge-status">Unknown</span>';
							}
						}
					},
					{
						title: "Action",
						data: null,
						orderable: false,
						className: "text-center",
						render: function (data, type, row) {
							return '<div class="btn-group flex-nowrap">' +
								'<button type="button" class="btn btn-info btn-sm btn-flat" data-toggle="tooltip" data-placement="top" title="Edit" ' +
								'onclick="fnLoadParialView(\'divformSave\', \'@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })?Id=' + row.Id + '\')">' +
								'<i class="far fa-edit"></i></button> ' +
								'<button type="button" class="btn btn-danger btn-sm btn-flat ml-2" data-toggle="tooltip" data-placement="top" title="Delete" ' +
								'onclick="fnDelete_Confirm(\'@Url.Action("DeleteConfirmed", "Orders", new { area = "Admin" })?Id=' + row.Id + '\')">' +
								'<i class="fa fa-trash"></i></button> ' +
									'<button type="button" class="btn btn-info btn-sm btn-flat ml-2" data-toggle="tooltip" data-placement="top" title="View" ' +
									'onclick="fnLoadParialView(\'divformSave\', \'@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })?Id=' + row.Id + '&Flag=VIEW\')">' +
									'<i class="fa fa-eye"></i></button> ' +

									'<button type="button" class="btn btn-info btn-sm btn-flat ml-2" data-toggle="tooltip" data-bs-placement="top" title="ViewItems" ' +
									'onclick="fnShow_Modal(\'@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })?Id=' + row.Id + '&Flag=VIEWITEMS\',\'Order Items\',true,\'html\',false,false)">' +
									'<i class="fa fa-list"></i></button>' +
								'</div>';
						}
					}
				 ],
				"initComplete": function () {

					if ($('#table_Common_Data_filter #btnChangeStatus').length === 0) {
						var btn = `
							<button id="btnChangeStatus" class="btn btn-primary btn-sm mr-2">
								<i class="fa fa-sync"></i> Change Status
							</button>
						`;

						// Insert BEFORE search box
						$('#table_Common_Data_filter').prepend(btn);
						//$('#table_Common_Data_filter').addClass('d-flex align-items-end gap-2');
					}
				},
				"fnDrawCallback": function (settings) {

					var api = this.api(); // ✅ FIX: define api
					var res = settings.json;

					// ✅ Update counts
					if (res && res.StatusCounts) {
						$('#count_ALL').text(res.StatusCounts.All);
						$('#count_PEND').text(res.StatusCounts.Pending);
						$('#count_CONF').text(res.StatusCounts.Confirmed);
						$('#count_PROC').text(res.StatusCounts.Processing);
						$('#count_COMP').text(res.StatusCounts.Completed);
						$('#count_CANC').text(res.StatusCounts.Cancelled);
						$('#count_RET').text(res.StatusCounts.Returned);
					}

					// ✅ Reset checkboxes (current page only)
					$('#chkAll').prop('checked', false);
					$('#table_Common_Data .chkRow').prop('checked', false);

					// ✅ Get data safely
					var data = res?.aaData || [];

					let isSameStatus = true;

					if (data.length > 0) {
						let firstStatus = data[0].OrderStatus;

						// ✅ Use for loop (break works)
						for (let i = 1; i < data.length; i++) {
							if (data[i].OrderStatus !== firstStatus) {
								isSameStatus = false;
								break;
							}
						}
					} else {
						isSameStatus = false;
					}

					// ✅ Column index (checkbox column)
					var columnIndex = 0;

					if (isSameStatus) {
						api.column(columnIndex).visible(true);
						$('#table_Common_Data_filter #btnChangeStatus').show();
					} else {
						api.column(columnIndex).visible(false);
						$('#table_Common_Data_filter #btnChangeStatus').hide();
					}
				}
				//,
				// "drawCallback": function () {
				// 	loadStatusCounts();
				// }
			});
		}

		$(document).on('change', '#chkAll', function () {

			let isChecked = $(this).is(':checked');

			// Only affect current page rows
			$('#table_Common_Data tbody .chkRow').prop('checked', isChecked);
		});

		$(document).on('change', '#table_Common_Data .chkRow', function () {

			let total = $('#table_Common_Data tbody .chkRow').length;
			let checked = $('#table_Common_Data tbody .chkRow:checked').length;

			// Update header checkbox
			$('#chkAll').prop('checked', total === checked);
		});

		$('.status-filter').on('click', '.status-btn', function () {

			$('.status-btn').removeClass('active');
			$(this).addClass('active');

			fnLoadTableData(); // reload table
		});

		$(document).on('click', '#btnChangeStatus', function () {

			var ids = [];
			$('.chkRow:checked').each(function () {
				ids.push($(this).val());
			});

			if (ids.length === 0) {
				Swal.fire("Warning", "Please select at least one order", "warning");
				return;
			}

			// ✅ Get current status
			let data = table_Common_Data.rows({ page: 'current' }).data();
			debugger;
			if (data.length === 0) return null;
			let currentStatus = data[0].OrderStatus;

			if (!currentStatus) {
				Swal.fire("Error", "Unable to determine current status", "error");
				return;
			}

			// ✅ Get allowed next statuses
			let allowedStatuses = statusFlow[currentStatus] || [];

			if (allowedStatuses.length === 0) {
				Swal.fire("Info", "No further status changes allowed", "info");
				return;
			}

			// ✅ Build dropdown dynamically
			let inputOptions = {};
			allowedStatuses.forEach(s => {
				inputOptions[s] = statusLabels[s];
			});

			Swal.fire({
				title: 'Change Order Status',
				input: 'select',
				inputOptions: inputOptions,
				inputPlaceholder: 'Select status',
				showCancelButton: true,
				inputValidator: (value) => {
					if (!value) {
						return 'Please select a status';
					}
				}
			}).then((result) => {

				if (result.isConfirmed) {

					$.ajax({
						url: '@Url.Action("UpdateStatus", "Orders", new { area = "Admin" })',
						type: 'POST',
						data: {
							ids: ids,
							status: result.value
						},
						traditional: true,
						success: function (res) {
							debugger;
							if (res.IsSuccess) {
								$('#chkAll').prop('checked', false);
								$('#table_Common_Data').DataTable().ajax.reload(null, false);
								Swal.fire("Success", res.Message || "Updated successfully", "success");

							} else Swal.fire("Error", res.Message || "Failed to update", "error");
						}
					});
				}
			});
		});

		// $(document).on('click', '#btnChangeStatus', function () {

		// 	var ids = [];
		// 	$('.chkRow:checked').each(function () { ids.push($(this).val()); });

		// 	if (ids && ids.length === 0) {
