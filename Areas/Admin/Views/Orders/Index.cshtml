@model ResponseModel<Orders>
@{
	ViewData["Title"] = "Orders";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
	<div class="container-fluid">
		<div class="row mb-2">
			<div class="col-sm-6">
				<h1 class="m-0 font-weight-bold">Category</h1>
			</div>
			<div class="col-sm-6">
				<div class="float-sm-right">
					<button type="button" id="btnAddNewItem" class="btn btn-primary btn-md pull-right mr-2 divformSave_Hide"
							onclick="fnLoadParialView('divformSave', '@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })');">
						<i class="fas fa-plus"></i> &nbsp; Add Order
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<section class="content">
	<div class="container-fluid">
		<div class="row no-gutters divformSave_Display d-none" style="margin: 5px !important;">
			<div class="col-12">
				<form id="formSave" asp-area="Admin" asp-controller="Orders" asp-action="Save" method="post" class="form-horizontal" enctype="multipart/form-data">
					<div class="row no-gutters" id="divformSave"></div>
					<div class="clearfix"></div>
					<hr />
				</form>
			</div>
		</div>
		<div class="row divformSave_Hide">
			<div class="col-12">
				<div class="card card-primary card-outline">

					<div class="card-body">
						<div class="row no-gooters">
							<div class="col-md-12 my-1">
								<table id="table_Common_Data" class="table table-bordered table-striped w-100"> </table>
							</div>

							<div class="clearfix"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>



@section Scripts
{
	<script type="text/javascript">

		$(document).ready(function () { fnLoadTableData(); });

		function fnLoadTableData() {

			if ($.fn.DataTable.isDataTable('#table_Common_Data')) { $('#table_Common_Data').DataTable().destroy(); }

			$("#table_Common_Data").DataTable({
				"destroy": true,
				"paging": true,
				"lengthChange": true,
				"searching": true,
				"ordering": true,
				"info": true,
				"autoWidth": false,
				"responsive": true,
				"pageLength": 25,
				"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
				"sAjaxSource": "@Url.Action("GetDataList", "Orders", new { area = "Admin" })",
				"bServerSide": true,
				"bProcessing": true,
				"bSearchable": true,
				"order": [[2, 'asc']],
				"language": { "emptyTable": "No record found.", "processing": '<i class="fa fa-spinner fa-spin fa-3x fa-fw" style="color:#2a2b2b;"></i><span class="sr-only">Loading...</span> ' },
				"fnServerParams": function (aoData) {
					//aoData.push({ "name": "SearchTerm", "value": "" + $('#inputSearch').val() });
				},
				columnDefs: [
					{ "targets": 0, "className": "text-center", "width": "3%", "autoWidth": false, "searchable": false, "orderable": false },
					{ "targets": -1, "className": "text-center", "width": "5%", "autoWidth": false, "searchable": false, "orderable": false }
				],
				"columns": [
					{
						title: "<input type='checkbox' id='chkAll' />",
						data: "Id",
						render: function (data) { return '<input type="checkbox" class="chkRow" value="' + data + '" />'; }
					},
					{ title: "Sr.No.", data: "SrNo", width: "5%", className: "text-center" },
					{ title: "Order No.", data: "OrderNumber" },
					{
					title: "Order Date",
					data: "OrderDate",
					render: function (data, type, row) {
						if (data) {
							var date = new Date(data);
							var day = ("0" + date.getDate()).slice(-2);
							var monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
											  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
							var month = monthNames[date.getMonth()];
							var year = date.getFullYear();

							return day + "-" + month + "-" + year;
						}
						return "";
					}
					},
					{ title: "No.Of.Items", data: "No_Of_Items" },
					{ title: "Final Amount", data: "FinalAmount" },
					{
						title: "Status",
						data: "OrderStatus",
						className: "text-center",
						render: function (data) { return data == 'PEND' ? '<span class="badge badge-danger">Pending</span>' : '<span class="badge badge-success">Completed</span>'; }
					},
					{
						title: "Action",
						data: null,
						orderable: false,
						className: "text-center",
						render: function (data, type, row) {
							return '<div class="btn-group">' +
								'<button type="button" class="btn btn-info btn-sm btn-flat" data-toggle="tooltip" data-placement="top" title="Edit" ' +
								'onclick="fnLoadParialView(\'divformSave\', \'@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })?Id=' + row.Id + '\')">' +
								'<i class="far fa-edit"></i></button> ' +
								'<button type="button" class="btn btn-danger btn-sm btn-flat ml-2" data-toggle="tooltip" data-placement="top" title="Delete" ' +
								'onclick="fnDelete_Confirm(\'@Url.Action("DeleteConfirmed", "Orders", new { area = "Admin" })?Id=' + row.Id + '\')">' +
								'<i class="fa fa-trash"></i></button> ' +
								'<button type="button" class="btn btn-info btn-sm btn-flat ml-2" data-toggle="tooltip" data-placement="top" title="Delete" ' +
								'onclick="fnLoadParialView(\'divformSave\', \'@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })?Id=' + row.Id + '&Flag=VIEW\')">' +
								'View</button> ' +
										'<button type="button" class="btn btn-info btn-sm btn-flat ml-2" data-bs-toggle="tooltip" data-bs-placement="top" title="View" ' +
										'onclick="fnShow_Modal(\'@Url.Action("Partial_AddEditForm", "Orders", new { area = "Admin" })?Id=' + row.Id + '&Flag=VIEWITEMS\',\'Order Items\',true,\'html\',false,false)">' +
										'View Item</button>' +
								'</div>';
						}
					}
				]
			});
		}

		function fnParialView_Loaded_Success($id, $isAlert){
			debugger;
			initImageUploader();
		}
		function fnBtnAddNewItem() {

			var rowCount = $('#orderItemsTable tbody tr').length;
			let newRowId = "tr_" + rowCount;
			let varaintlist = @Html.Raw(Json.Serialize(Model.SelectListItems.Where(x => x.Group == "VARIANT")));
			var options = '<option value="0">Select</option>';

				varaintlist.forEach(varaint => {
					options += `<option value="${varaint.Value}" data-value="${varaint.Value4}">${varaint.Text}</option>`;
				});

			let newRow = `<tr id="${newRowId}">
			<td width="10%">
					<select class="form-control show-tick select2"
						id="ListOrderItems_${rowCount}_VariantId"
						name="ListOrderItems[${rowCount}].VariantId" onchange="onProductVaraintChange(this)" >
						${options}
					</select>
			</td>
			<td><input type="text" id="ListOrderItems_${rowCount}_Quantity" name="ListOrderItems[${rowCount}].Quantity" class="form-control isNumberKey_Decimal" value="" onkeyup="calculateRow(this),calculateTotals()" /></td>
			<td><input type="text" id="ListOrderItems_${rowCount}_UnitPrice" name="ListOrderItems[${rowCount}].UnitPrice" class="form-control isNumberKey_Decimal" value="" readonly /></td>
			<td><input type="text" id="ListOrderItems_${rowCount}_TotalPrice" name="ListOrderItems[${rowCount}].TotalPrice" class="form-control isNumberKey_Decimal" value="" readonly /></td>
			<td><div><button type="button" class="btn btn-danger btn-sm btn-flat ml-2 deletebtn" data-toggle="tooltip" data-placement="top" title="Delete" onclick="deleteRow(this)">
			<i class="fa fa-trash"></i></button></div></td></tr>`;


			  setTimeout(() => {
				$(".select2").select2();
			}, 100);
			$("#orderItemsTable tbody").append(newRow);

			rowCount++;
		}

		$(document).on('click', '.deletebtn', function () {
			$(this).closest('tr').remove(); // Find the closest row (<tr>) to the clicked delete button and remove it
			calculateTotals();
		});
		function onProductVaraintChange(element) {

			var row = $(element).closest("tr");

			var price = $(element).find("option:selected").data("value") || 0;

			row.find("[id*='UnitPrice']").val(price);
			row.find("[id*='Quantity']").val(1);

			var total = price * 1;
			row.find("[id*='TotalPrice']").val(total.toFixed(2));

			calculateTotals();
		}
		function calculateRow(element) {

			var row = $(element).closest("tr");

			var qty = parseFloat(row.find("[id*='Quantity']").val()) || 0;
			var price = parseFloat(row.find("[id*='UnitPrice']").val()) || 0;

			var total = qty * price;

			row.find("[id*='TotalPrice']").val(total.toFixed(2));

			calculateTotals();
		}
		function calculateTotals() {

			var totalAmount = 0;

			$("#orderItemsTable tbody tr").each(function () {

				var total = parseFloat($(this).find("[id*='TotalPrice']").val()) || 0;
				totalAmount += total;

			});

			$("#TotalAmount").val(totalAmount.toFixed(2));

			var discount = parseFloat($("#DiscountAmount").val()) || 0;

			var finalAmount = totalAmount - discount;

			$("#FinalAmount").val(finalAmount.toFixed(2));
		}
	</script>
}
